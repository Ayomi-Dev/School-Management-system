// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  TUTOR
  STUDENT
  PARENT
  BURSAR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TokenType {
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ClassLevel {
  CRECHE
  NURSERY1
  NURSERY2
  PRIMARY1
  PRIMARY2
  PRIMARY3
  PRIMARY4
  PRIMARY5
  PRIMARY6
  JSS1
  JSS2
  JSS3
  SS1
  SS2
  SS3
}

enum Department {
  ART
  COMMERCIAL
  SCIENCE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  UNMARKED
}

enum TermPeriod {
  FIRST
  SECOND
  THIRD
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
  WITHDRAWN
}

enum ReportCardStatus {
  DRAFT
  PUBLISHED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  ONLINE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationEventType {
  STUDENT_ABSENT
  GRADE_PUBLISHED
  REPORT_CARD_PUBLISHED
  FEE_PAYMENT_RECORDED
  FEE_REMINDER
  ANNOUNCEMENT
  OTP_SENT
}

enum AnnouncementTarget {
  SCHOOL
  CLASS
  INDIVIDUAL
}

// ============================================================
// SCHOOL
// ============================================================

model School {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  address   String?
  phone     String?
  email     String?
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  academicYears   AcademicYear[]
  classes         Class[]
  subjects        Subject[]
  studentProfiles StudentProfile[]
  tutorProfiles   TutorProfile[]
  feeStructures   FeeStructure[]
  announcements   Announcement[]
  notifications   Notification[]
  createdById  String?            @map("created_by_id") @db.ObjectId
  createdBy   SuperAdminProfile? @relation("SchoolCreatedBy", fields:   [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction )

  @@map("schools")
}

// ============================================================
// AUTH & IDENTITY
// ============================================================

model SuperAdminProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @map("user_id") @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolsCreated School[] @relation("SchoolCreatedBy")

  @@map("super_admin_profiles")
}

model User {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId            String?    @map("school_id") @db.ObjectId
  role                Role      @default(STUDENT)
  email               String    @unique
  passwordHash        String?   @map("password_hash")
  phone               String?
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  userCode            String?   @unique @map("user_code")
  status              UserStatus   @default(ACTIVE)
  isActive            Boolean   @default(true) @map("is_active")
  isEmailVerified     Boolean   @default(false) @map("is_email_verified")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  lastLoginAt         DateTime? @map("last_login_at")
  failedLoginCount    Int       @default(0) @map("failed_login_count")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  school                School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tokens                Token[]
  otpCodes              OtpCode[]
  auditLogs             AuditLog[]
  superAdminProfile SuperAdminProfile?
  studentProfile        StudentProfile?
  tutorProfile          TutorProfile?
  guardianProfile       Guardian?
  sentNotifications     Notification[]     @relation("NotificationSender")
  userNotifications     UserNotification[]
  announcementsAuthored Announcement[]

  @@unique([email, schoolId])
  @@unique([phone, schoolId])
  @@index([schoolId, role])
  @@map("users")
}

model Token {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @map("user_id") @db.ObjectId
  tokenHash String    @unique @map("token_hash")
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  isRevoked Boolean   @default(false) @map("is_revoked")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("tokens")
}

model OtpCode {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @map("user_id") @db.ObjectId
  phone     String
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  attempts  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@map("otp_codes")
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @map("user_id") @db.ObjectId
  schoolId   String?  @map("school_id") @db.ObjectId
  action     String
  resource   String?
  resourceId String?  @map("resource_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  statusCode Int?     @map("status_code")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// SCHOOL STRUCTURE
// ============================================================

model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String   @map("school_id") @db.ObjectId
  label     String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  school      School       @relation(fields: [schoolId], references: [id])
  terms       Term[]
  enrollments Enrollment[]
  reportCards ReportCard[]

  @@unique([schoolId, label])
  @@index([schoolId])
  @@map("academic_years")
}

model Term {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  academicYearId String     @map("academic_year_id") @db.ObjectId
  period         TermPeriod
  startDate      DateTime   @map("start_date")
  endDate        DateTime   @map("end_date")
  isCurrent      Boolean    @default(false) @map("is_current")
  createdAt      DateTime   @default(now()) @map("created_at")

  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id])
  classSessions ClassSession[]
  scores        Score[]
  feeStructures FeeStructure[]
  feePayments   FeePayment[]
  reportCards   ReportCard[]

  @@unique([academicYearId, period])
  @@map("terms")
}

model Class {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId   String      @map("school_id") @db.ObjectId
  name       String
  level      ClassLevel
  order      Int
  department Department?
  createdAt  DateTime    @default(now()) @map("created_at")

  school             School                   @relation(fields: [schoolId], references: [id])
  enrollments        Enrollment[]
  teacherAssignments TeacherClassAssignment[]
  classSessions      ClassSession[]
  subjectTeachers    SubjectTeacher[]
  feeStructures      FeeStructure[]
  announcements      Announcement[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

model Subject {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String  @map("school_id") @db.ObjectId
  name     String
  code     String?

  school          School           @relation(fields: [schoolId], references: [id])
  scores          Score[]
  subjectTeachers SubjectTeacher[]

  @@unique([schoolId, name])
  @@map("subjects")
}

model CodeCounter {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String  @map("school_id") @db.ObjectId
  type      String // STUDENT, STAFF
  year      Int?
  term      TermPeriod?
  value     Int    @default(0)

  @@unique([schoolId, type, year, term])
}

// ============================================================
// STUDENTS
// ============================================================

model Guardian {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  userId       String  @unique @map("user_id") @db.ObjectId
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  phone        String
  email        String?
  relationship String?

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  children GuardianStudent[]

  @@map("guardians")
}

// MongoDB does not support composite @@id with @db.ObjectId
// so we use a surrogate String id and enforce uniqueness via @@unique
model GuardianStudent {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  guardianId String   @map("guardian_id") @db.ObjectId
  studentId  String   @map("student_id") @db.ObjectId
  isPrimary  Boolean  @default(false) @map("is_primary")
  addedAt    DateTime @default(now()) @map("added_at")

  guardian Guardian       @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student  StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
  @@map("guardian_students")
}

model StudentProfile {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @unique @map("user_id") @db.ObjectId
  schoolId      String        @map("school_id") @db.ObjectId
  studentNumber String        @unique @map("student_number")
  firstName     String        @map("first_name")
  middleName    String?       @map("middle_name")
  lastName      String        @map("last_name")
  dateOfBirth   DateTime?     @map("date_of_birth")
  gender        Gender
  photoUrl      String?       @map("photo_url")
  status        StudentStatus @default(ACTIVE)
  deletedAt     DateTime?     @map("deleted_at")
  exitReason    String?       @map("exit_reason")
  enrolledAt    DateTime      @default(now()) @map("enrolled_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  school      School            @relation(fields: [schoolId], references: [id])
  guardians   GuardianStudent[]
  enrollments Enrollment[]
  attendances Attendance[]
  scores      Score[]
  feeBalances FeeBalance[]
  feePayments FeePayment[]
  reportCards ReportCard[]

  @@index([schoolId, status])
  @@map("student_profiles")
}

model Enrollment {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String    @map("student_id") @db.ObjectId
  classId        String    @map("class_id") @db.ObjectId
  academicYearId String    @map("academic_year_id") @db.ObjectId
  enrolledAt     DateTime  @default(now()) @map("enrolled_at")
  promotedAt     DateTime? @map("promoted_at")
  promotedFromId String?   @map("promoted_from_id") @db.ObjectId

  student      StudentProfile @relation(fields: [studentId], references: [id])
  class        Class          @relation(fields: [classId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([classId, academicYearId])
  @@map("enrollments")
}

// ============================================================
// TEACHERS
// ============================================================

model TutorProfile {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  userId         String      @unique @map("user_id") @db.ObjectId
  schoolId       String      @map("school_id") @db.ObjectId
  employeeNumber String      @unique @map("employee_number")
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  phone          String?
  department     Department?
  hiredAt        DateTime    @default(now()) @map("hired_at")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school            School                   @relation(fields: [schoolId], references: [id])
  classAssignments  TeacherClassAssignment[]
  subjectTeachers   SubjectTeacher[]
  classSessions     ClassSession[]
  attendancesMarked Attendance[]             @relation("AttendanceMarkedBy")
  scoresEntered     Score[]                  @relation("ScoreEnteredBy")

  @@map("tutor_profiles")
}

model TeacherClassAssignment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tutorId        String   @map("tutor_id") @db.ObjectId
  classId        String   @map("class_id") @db.ObjectId
  academicYearId String   @map("academic_year_id") @db.ObjectId
  isClassTeacher Boolean  @default(false) @map("is_class_teacher")
  assignedAt     DateTime @default(now()) @map("assigned_at")

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  class Class        @relation(fields: [classId], references: [id])

  @@unique([tutorId, classId, academicYearId])
  @@map("teacher_class_assignments")
}

model SubjectTeacher {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tutorId    String   @map("tutor_id") @db.ObjectId
  subjectId  String   @map("subject_id") @db.ObjectId
  classId    String   @map("class_id") @db.ObjectId
  termId     String   @map("term_id") @db.ObjectId
  assignedAt DateTime @default(now()) @map("assigned_at")

  tutor   TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  subject Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class        @relation(fields: [classId], references: [id])

  @@unique([tutorId, subjectId, classId, termId])
  @@map("subject_teachers")
}

// ============================================================
// ATTENDANCE
// ============================================================

model ClassSession {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  classId     String    @map("class_id") @db.ObjectId
  termId      String    @map("term_id") @db.ObjectId
  tutorId     String?   @map("tutor_id") @db.ObjectId
  date        DateTime
  label       String?
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at")

  class       Class         @relation(fields: [classId], references: [id])
  term        Term          @relation(fields: [termId], references: [id])
  tutor       TutorProfile? @relation(fields: [tutorId], references: [id])
  attendances Attendance[]

  @@unique([classId, date, label])
  @@index([classId, date])
  @@map("class_sessions")
}

model Attendance {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  sessionId  String           @map("session_id") @db.ObjectId
  studentId  String           @map("student_id") @db.ObjectId
  status     AttendanceStatus @default(UNMARKED)
  remark     String?
  markedById String?          @map("marked_by_id") @db.ObjectId
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  session   ClassSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  markedBy  TutorProfile?  @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance")
}

// ============================================================
// ACADEMICS
// ============================================================

model Score {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String  @map("student_id") @db.ObjectId
  subjectId   String  @map("subject_id") @db.ObjectId
  termId      String  @map("term_id") @db.ObjectId
  enteredById String? @map("entered_by_id") @db.ObjectId

  caScore    Float?
  examScore  Float?  @map("exam_score")
  totalScore Float?  @map("total_score")
  grade      String?
  gradeRemark String? @map("grade_remark")

  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  student   StudentProfile @relation(fields: [studentId], references: [id])
  subject   Subject        @relation(fields: [subjectId], references: [id])
  term      Term           @relation(fields: [termId], references: [id])
  enteredBy TutorProfile?  @relation("ScoreEnteredBy", fields: [enteredById], references: [id])

  @@unique([studentId, subjectId, termId])
  @@index([termId, subjectId])
  @@map("scores")
}

model ReportCard {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String           @map("student_id") @db.ObjectId
  termId         String           @map("term_id") @db.ObjectId
  academicYearId String           @map("academic_year_id") @db.ObjectId
  classSnapshot  String?          @map("class_snapshot")
  pdfUrl         String?          @map("pdf_url")
  status         ReportCardStatus @default(DRAFT)
  totalScore     Float?           @map("total_score")
  average        Float?
  position       Int?
  teacherRemark  String?          @map("teacher_remark")
  principalRemark String?         @map("principal_remark")
  publishedAt    DateTime?        @map("published_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  student      StudentProfile @relation(fields: [studentId], references: [id])
  term         Term           @relation(fields: [termId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, termId])
  @@map("report_cards")
}

// ============================================================
// FEES
// ============================================================

model FeeStructure {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId   String   @map("school_id") @db.ObjectId
  classId    String?  @map("class_id") @db.ObjectId
  termId     String   @map("term_id") @db.ObjectId
  name       String
  amount     Float
  isOptional Boolean  @default(false) @map("is_optional")
  createdAt  DateTime @default(now()) @map("created_at")

  school   School       @relation(fields: [schoolId], references: [id])
  class    Class?       @relation(fields: [classId], references: [id])
  term     Term         @relation(fields: [termId], references: [id])
  balances FeeBalance[]

  @@map("fee_structures")
}

model FeeBalance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String   @map("student_id") @db.ObjectId
  feeStructureId String   @map("fee_structure_id") @db.ObjectId
  amountDue      Float    @map("amount_due")
  amountPaid     Float    @default(0) @map("amount_paid")
  updatedAt      DateTime @updatedAt @map("updated_at")

  student      StudentProfile @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure   @relation(fields: [feeStructureId], references: [id])

  @@unique([studentId, feeStructureId])
  @@map("fee_balances")
}

model FeePayment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String        @map("student_id") @db.ObjectId
  termId         String        @map("term_id") @db.ObjectId
  feeStructureId String?       @map("fee_structure_id") @db.ObjectId
  receiptNumber  String        @unique @map("receipt_number")
  amount         Float
  paymentDate    DateTime      @map("payment_date")
  paymentMethod  PaymentMethod @default(CASH) @map("payment_method")
  recordedById   String?       @map("recorded_by_id") @db.ObjectId
  note           String?
  createdAt      DateTime      @default(now()) @map("created_at")

  student StudentProfile @relation(fields: [studentId], references: [id])
  term    Term           @relation(fields: [termId], references: [id])

  @@index([studentId, termId])
  @@map("fee_payments")
}

// ============================================================
// COMMS
// ============================================================

model Announcement {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String             @map("school_id") @db.ObjectId
  authorId     String             @map("author_id") @db.ObjectId
  title        String
  body         String
  target       AnnouncementTarget
  classId      String?            @map("class_id") @db.ObjectId
  targetUserId String?            @map("target_user_id") @db.ObjectId
  scheduledAt  DateTime?          @map("scheduled_at")
  publishedAt  DateTime?          @map("published_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  school        School         @relation(fields: [schoolId], references: [id])
  author        User           @relation(fields: [authorId], references: [id])
  class         Class?         @relation(fields: [classId], references: [id])
  notifications Notification[]

  @@index([schoolId, publishedAt])
  @@map("announcements")
}

model Notification {
  id             String                @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String                @map("school_id") @db.ObjectId
  eventType      NotificationEventType @map("event_type")
  announcementId String?               @map("announcement_id") @db.ObjectId
  sentById       String?               @map("sent_by_id") @db.ObjectId
  payload        Json
  createdAt      DateTime              @default(now()) @map("created_at")

  school       School             @relation(fields: [schoolId], references: [id])
  sentBy       User?              @relation("NotificationSender", fields: [sentById], references: [id])
  announcement Announcement?      @relation(fields: [announcementId], references: [id])
  deliveries   UserNotification[]

  @@index([schoolId, createdAt])
  @@map("notifications")
}

model UserNotification {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  notificationId String              @map("notification_id") @db.ObjectId
  userId         String              @map("user_id") @db.ObjectId
  channel        NotificationChannel
  isRead         Boolean             @default(false) @map("is_read")
  readAt         DateTime?           @map("read_at")
  deliveredAt    DateTime?           @map("delivered_at")
  failedAt       DateTime?           @map("failed_at")
  externalId     String?             @map("external_id")
  createdAt      DateTime            @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId, channel])
  @@index([userId, isRead])
  @@map("user_notifications")
}