// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


// ============================================================
// School Management Platform — Prisma Schema (v2)
// ============================================================
//
// Domains:
//   1.  Enums
//   2.  School  (multi-tenant root)
//   3.  Auth & Identity  (User, Token, OtpCode, AuditLog)
//   4.  School Structure  (AcademicYear, Term, Class, Subject)
//   5.  Students  (StudentProfile, Guardian, GuardianStudent, Enrollment)
//   6.  Teachers  (TutorProfile, TeacherClassAssignment, SubjectTeacher)
//   7.  Attendance  (ClassSession, Attendance)
//   8.  Academics  (Score, ReportCard)
//   9.  Fees  (FeeStructure, FeeBalance, FeePayment)
//  10.  Comms  (Announcement, Notification, UserNotification)
// ============================================================


// ============================================================
// 1. ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  TUTOR
  STUDENT
  PARENT
  BURSAR
}

enum TokenType {
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ClassLevel {
  CRECHE
  NURSERY1
  NURSERY2
  PRIMARY1
  PRIMARY2
  PRIMARY3
  PRIMARY4
  PRIMARY5
  PRIMARY6
  JSS1
  JSS2
  JSS3
  SS1
  SS2
  SS3
}

enum Department {
  ART
  COMMERCIAL
  SCIENCE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// UNMARKED is the default — distinguishes "register not done yet"
// from "teacher confirmed the student was absent."
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  UNMARKED
}

enum TermPeriod {
  FIRST
  SECOND
  THIRD
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
  WITHDRAWN
}

enum ReportCardStatus {
  DRAFT
  PUBLISHED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  POS
  ONLINE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationEventType {
  STUDENT_ABSENT
  GRADE_PUBLISHED
  REPORT_CARD_PUBLISHED
  FEE_PAYMENT_RECORDED
  FEE_REMINDER
  ANNOUNCEMENT
  OTP_SENT
}

enum AnnouncementTarget {
  SCHOOL
  CLASS
  INDIVIDUAL
}

// ============================================================
// 2. SCHOOL  (multi-tenant root)
// ============================================================

model School {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  academicYears   AcademicYear[]
  classes         Class[]
  subjects        Subject[]
  studentProfiles StudentProfile[]
  tutorProfiles   TutorProfile[]
  feeStructures   FeeStructure[]
  announcements   Announcement[]
  notifications   Notification[]

  @@map("schools")
}

// ============================================================
// 3. AUTH & IDENTITY
// ============================================================

// One User row per human per school.
// email  → required for ADMIN / TUTOR / BURSAR
// phone  → required for STUDENT / PARENT (OTP login)
model User {
  id               String    @id @default(uuid())
  schoolId         String    @map("school_id")
  role             Role      @default(STUDENT)
  email            String?
  passwordHash     String?   @map("password_hash")
  phone            String?   // Always String — leading zeros, +234 prefix
  isActive         Boolean   @default(true) @map("is_active")
  isEmailVerified  Boolean   @default(false) @map("is_email_verified")
  lastLoginAt      DateTime? @map("last_login_at")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  school                School             @relation(fields: [schoolId], references: [id])
  tokens                Token[]
  otpCodes              OtpCode[]
  auditLogs             AuditLog[]
  studentProfile        StudentProfile?
  tutorProfile          TutorProfile?
  guardianProfile       Guardian?
  sentNotifications     Notification[]     @relation("NotificationSender")
  userNotifications     UserNotification[]
  announcementsAuthored Announcement[]

  @@unique([email, schoolId])
  @@unique([phone, schoolId])
  @@index([schoolId, role])
  @@map("users")
}

// Raw token is returned once in the HTTP response and discarded.
// Only a SHA-256 hash is stored — a DB breach cannot hijack sessions.
model Token {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  isRevoked Boolean   @default(false) @map("is_revoked")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("tokens")
}

// Phone-based OTP for PARENT / STUDENT login.
// 6-digit code is bcrypt-hashed. Max attempts enforced at app layer.
model OtpCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  phone     String
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  attempts  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@map("otp_codes")
}

// Immutable audit trail. userId nullable so unauthenticated
// events (failed logins) are still recorded.
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  schoolId   String?  @map("school_id")
  action     String   // "GRADE_UPDATED", "STUDENT_PROMOTED", "FEE_RECORDED"
  resource   String?  // Model name: "Score", "Enrollment"
  resourceId String?  @map("resource_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  statusCode Int?     @map("status_code")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// 4. SCHOOL STRUCTURE
// ============================================================

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  label     String   // "2024/2025"
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  school      School       @relation(fields: [schoolId], references: [id])
  terms       Term[]
  enrollments Enrollment[]
  reportCards ReportCard[]

  @@unique([schoolId, label])
  @@index([schoolId])
  @@map("academic_years")
}

model Term {
  id             String     @id @default(uuid())
  academicYearId String     @map("academic_year_id")
  period         TermPeriod
  startDate      DateTime   @map("start_date")
  endDate        DateTime   @map("end_date")
  isCurrent      Boolean    @default(false) @map("is_current")
  createdAt      DateTime   @default(now()) @map("created_at")

  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id])
  classSessions ClassSession[]
  scores        Score[]
  feeStructures FeeStructure[]
  feePayments   FeePayment[]
  reportCards   ReportCard[]

  @@unique([academicYearId, period])
  @@map("terms")
}

// Class is a concrete teaching group — "JSS 2A", "JSS 2B", "Primary 4".
// A ClassLevel enum alone cannot represent parallel streams (A/B/C).
// level is the canonical anchor used for bulk promotion logic.
// order is explicit so the UI can sort without relying on enum ordinals.
model Class {
  id         String      @id @default(uuid())
  schoolId   String      @map("school_id")
  name       String      // "JSS 2A", "Primary 4B"
  level      ClassLevel
  order      Int         // 1 = Creche … 15 = SS3
  department Department? // SS-only; null for primary/junior

  createdAt DateTime @default(now()) @map("created_at")

  school             School                   @relation(fields: [schoolId], references: [id])
  enrollments        Enrollment[]
  teacherAssignments TeacherClassAssignment[]
  classSessions      ClassSession[]
  subjectTeachers    SubjectTeacher[]
  feeStructures      FeeStructure[]
  announcements      Announcement[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

model Subject {
  id       String  @id @default(uuid())
  schoolId String  @map("school_id")
  name     String  // "Mathematics", "Yoruba"
  code     String? // "MTH", "YOR"

  school          School           @relation(fields: [schoolId], references: [id])
  scores          Score[]
  subjectTeachers SubjectTeacher[]

  @@unique([schoolId, name])
  @@map("subjects")
}

// ============================================================
// 5. STUDENTS
// ============================================================

// Guardian is separate so one parent account can link
// to multiple children (siblings in the same school).
model Guardian {
  id           String  @id @default(uuid())
  userId       String  @unique @map("user_id")
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  phone        String  // Primary SMS contact for absence alerts
  email        String?
  relationship String? // "Mother", "Father", "Uncle"

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  children GuardianStudent[]

  @@map("guardians")
}

// One student can have multiple guardians (mother + father).
// One guardian can have multiple children (siblings).
// isPrimary flags who gets notified first.
model GuardianStudent {
  guardianId String   @map("guardian_id")
  studentId  String   @map("student_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  addedAt    DateTime @default(now()) @map("added_at")

  guardian Guardian       @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student  StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([guardianId, studentId])
  @@map("guardian_students")
}

model StudentProfile {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  schoolId      String        @map("school_id")
  studentNumber String        @unique @map("student_number") // "SCH/2024/001"
  firstName     String        @map("first_name")
  middleName    String?       @map("middle_name")
  lastName      String        @map("last_name")
  dateOfBirth   DateTime?     @map("date_of_birth")
  gender        Gender
  photoUrl      String?       @map("photo_url")
  status        StudentStatus @default(ACTIVE)

  // Soft delete — record preserved so historical grades,
  // attendance, and fees remain queryable after exit.
  deletedAt  DateTime? @map("deleted_at")
  exitReason String?   @map("exit_reason")

  enrolledAt DateTime @default(now()) @map("enrolled_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  school      School            @relation(fields: [schoolId], references: [id])
  guardians   GuardianStudent[]
  enrollments Enrollment[]
  attendances Attendance[]
  scores      Score[]
  feeBalances FeeBalance[]
  feePayments FeePayment[]
  reportCards ReportCard[]

  @@index([schoolId, status])
  @@map("student_profiles")
}

// Enrollment records which class a student belongs to per academic year.
// This is the mechanism for class history and bulk promotion.
// Bulk promotion = batch INSERT new Enrollment rows pointing to next class.
// promotedFromId chains to the previous year's enrollment.
model Enrollment {
  id             String    @id @default(uuid())
  studentId      String    @map("student_id")
  classId        String    @map("class_id")
  academicYearId String    @map("academic_year_id")
  enrolledAt     DateTime  @default(now()) @map("enrolled_at")
  promotedAt     DateTime? @map("promoted_at")
  promotedFromId String?   @map("promoted_from_id")

  student      StudentProfile @relation(fields: [studentId], references: [id])
  class        Class          @relation(fields: [classId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([classId, academicYearId])
  @@map("enrollments")
}

// ============================================================
// 6. TEACHERS (TUTORS)
// ============================================================

model TutorProfile {
  id             String      @id @default(uuid())
  userId         String      @unique @map("user_id")
  schoolId       String      @map("school_id")
  employeeNumber String      @unique @map("employee_number") // "TCH/2022/007"
  firstName      String      @map("first_name")
  lastName       String      @map("last_name")
  phone          String?
  department     Department?
  hiredAt        DateTime    @default(now()) @map("hired_at")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school            School                   @relation(fields: [schoolId], references: [id])
  classAssignments  TeacherClassAssignment[]
  subjectTeachers   SubjectTeacher[]
  classSessions     ClassSession[]
  attendancesMarked Attendance[]             @relation("AttendanceMarkedBy")
  scoresEntered     Score[]                  @relation("ScoreEnteredBy")

  @@map("tutor_profiles")
}

// Assigns a tutor as class teacher for a given year.
// isClassTeacher distinguishes homeroom teacher from subject-only tutors.
model TeacherClassAssignment {
  id             String   @id @default(uuid())
  tutorId        String   @map("tutor_id")
  classId        String   @map("class_id")
  academicYearId String   @map("academic_year_id")
  isClassTeacher Boolean  @default(false) @map("is_class_teacher")
  assignedAt     DateTime @default(now()) @map("assigned_at")

  tutor TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  class Class        @relation(fields: [classId], references: [id])

  @@unique([tutorId, classId, academicYearId])
  @@map("teacher_class_assignments")
}

// A tutor teaches a specific subject to a specific class this term.
// Scoped to term so mid-year reassignments are tracked cleanly.
model SubjectTeacher {
  id         String   @id @default(uuid())
  tutorId    String   @map("tutor_id")
  subjectId  String   @map("subject_id")
  classId    String   @map("class_id")
  termId     String   @map("term_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  tutor   TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  subject Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class        @relation(fields: [classId], references: [id])

  @@unique([tutorId, subjectId, classId, termId])
  @@map("subject_teachers")
}

// ============================================================
// 7. ATTENDANCE
// ============================================================

// ClassSession = one register event for a class on a given date.
// Tying attendance to a session (not just a date) allows multiple
// registers per day (morning / afternoon).
// isCompleted lets admin see which teachers haven't done their register.
model ClassSession {
  id          String    @id @default(uuid())
  classId     String    @map("class_id")
  termId      String    @map("term_id")
  tutorId     String?   @map("tutor_id")
  date        DateTime  @db.Date
  label       String?   // "Morning" / "Afternoon" — for multi-session days
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at")

  class       Class         @relation(fields: [classId], references: [id])
  term        Term          @relation(fields: [termId], references: [id])
  tutor       TutorProfile? @relation(fields: [tutorId], references: [id])
  attendances Attendance[]

  @@unique([classId, date, label])
  @@index([classId, date])
  @@map("class_sessions")
}

// Default is UNMARKED — teacher must actively complete the register.
// ABSENT status triggers a parent SMS notification via the notification worker.
model Attendance {
  id         String           @id @default(uuid())
  sessionId  String           @map("session_id")
  studentId  String           @map("student_id")
  status     AttendanceStatus @default(UNMARKED)
  remark     String?
  markedById String?          @map("marked_by_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  session   ClassSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  markedBy  TutorProfile?  @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance")
}

// ============================================================
// 8. ACADEMICS
// ============================================================

// Nigerian WAEC grading:
//   A1 75–100 | B2 70–74 | B3 65–69 | C4 60–64
//   C5 55–59  | C6 50–54 | D7 45–49 | E8 40–44 | F9 <40
//
// isPublished gives teachers a draft workflow.
// Flipping to true fires a GRADE_PUBLISHED notification automatically.
model Score {
  id          String  @id @default(uuid())
  studentId   String  @map("student_id")
  subjectId   String  @map("subject_id")
  termId      String  @map("term_id")
  enteredById String? @map("entered_by_id")

  caScore    Float?  @map("ca_score")    // Continuous Assessment — max 40
  examScore  Float?  @map("exam_score")  // End-of-term exam — max 60
  totalScore Float?  @map("total_score") // caScore + examScore; computed by app

  grade       String? // "A1" … "F9"
  gradeRemark String? @map("grade_remark") // "Excellent" | "Good" | "Fair" | "Pass" | "Fail"

  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student   StudentProfile @relation(fields: [studentId], references: [id])
  subject   Subject        @relation(fields: [subjectId], references: [id])
  term      Term           @relation(fields: [termId], references: [id])
  enteredBy TutorProfile?  @relation("ScoreEnteredBy", fields: [enteredById], references: [id])

  @@unique([studentId, subjectId, termId])
  @@index([termId, subjectId])
  @@map("scores")
}

// Auto-generated PDF report card at end of term.
// pdfUrl → object storage (S3 / Cloudflare R2).
// DRAFT until admin publishes; publishing fires REPORT_CARD_PUBLISHED notification.
model ReportCard {
  id             String           @id @default(uuid())
  studentId      String           @map("student_id")
  termId         String           @map("term_id")
  academicYearId String           @map("academic_year_id")
  classSnapshot  String?          @map("class_snapshot") // Class name frozen at generation time
  pdfUrl         String?          @map("pdf_url")
  status         ReportCardStatus @default(DRAFT)

  totalScore      Float?  @map("total_score")
  average         Float?
  position        Int?    // Class rank
  teacherRemark   String? @map("teacher_remark")
  principalRemark String? @map("principal_remark")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  student      StudentProfile @relation(fields: [studentId], references: [id])
  term         Term           @relation(fields: [termId], references: [id])
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, termId])
  @@map("report_cards")
}

// ============================================================
// 9. FEES
// ============================================================

// Template: what a class owes per term.
// classId = null → school-wide levy (applies to all classes).
// Multiple rows per class/term: Tuition + PTA Levy + Development Levy.
model FeeStructure {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  classId    String?  @map("class_id")
  termId     String   @map("term_id")
  name       String   // "Tuition Fee", "PTA Levy", "Development Levy"
  amount     Decimal  @db.Decimal(12, 2)
  isOptional Boolean  @default(false) @map("is_optional")
  createdAt  DateTime @default(now()) @map("created_at")

  school   School       @relation(fields: [schoolId], references: [id])
  class    Class?       @relation(fields: [classId], references: [id])
  term     Term         @relation(fields: [termId], references: [id])
  balances FeeBalance[]

  @@map("fee_structures")
}

// Per-student ledger for each fee line item.
// outstanding = amountDue - amountPaid  (computed by app — never stored)
model FeeBalance {
  id             String  @id @default(uuid())
  studentId      String  @map("student_id")
  feeStructureId String  @map("fee_structure_id")
  amountDue      Decimal @db.Decimal(12, 2) @map("amount_due")
  amountPaid     Decimal @db.Decimal(12, 2) @default(0) @map("amount_paid")

  updatedAt DateTime @updatedAt @map("updated_at")

  student      StudentProfile @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure   @relation(fields: [feeStructureId], references: [id])

  @@unique([studentId, feeStructureId])
  @@map("fee_balances")
}

// Immutable payment log — each bursar entry is one row, never updated.
// receiptNumber unique across the school.
// Recording a payment fires a FEE_PAYMENT_RECORDED notification to the guardian.
model FeePayment {
  id             String        @id @default(uuid())
  studentId      String        @map("student_id")
  termId         String        @map("term_id")
  feeStructureId String?       @map("fee_structure_id")
  receiptNumber  String        @unique @map("receipt_number")
  amount         Decimal       @db.Decimal(12, 2)
  paymentDate    DateTime      @map("payment_date")
  paymentMethod  PaymentMethod @default(CASH) @map("payment_method")
  recordedById   String?       @map("recorded_by_id") // Bursar's User.id
  note           String?
  createdAt      DateTime      @default(now()) @map("created_at")

  student StudentProfile @relation(fields: [studentId], references: [id])
  term    Term           @relation(fields: [termId], references: [id])

  @@index([studentId, termId])
  @@map("fee_payments")
}

// ============================================================
// 10. COMMS
// ============================================================

model Announcement {
  id           String             @id @default(uuid())
  schoolId     String             @map("school_id")
  authorId     String             @map("author_id")
  title        String
  body         String
  target       AnnouncementTarget
  classId      String?            @map("class_id")
  targetUserId String?            @map("target_user_id")
  scheduledAt  DateTime?          @map("scheduled_at")
  publishedAt  DateTime?          @map("published_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  school        School         @relation(fields: [schoolId], references: [id])
  author        User           @relation(fields: [authorId], references: [id])
  class         Class?         @relation(fields: [classId], references: [id])
  notifications Notification[]

  @@index([schoolId, publishedAt])
  @@map("announcements")
}

// One row per system event.
// payload is a flexible JSON bag: { studentName, className, amount, … }
// The notification worker reads this and fans out to UserNotification.
model Notification {
  id             String                @id @default(uuid())
  schoolId       String                @map("school_id")
  eventType      NotificationEventType @map("event_type")
  announcementId String?               @map("announcement_id")
  sentById       String?               @map("sent_by_id")
  payload        Json
  createdAt      DateTime              @default(now()) @map("created_at")

  school       School             @relation(fields: [schoolId], references: [id])
  sentBy       User?              @relation("NotificationSender", fields: [sentById], references: [id])
  announcement Announcement?      @relation(fields: [announcementId], references: [id])
  deliveries   UserNotification[]

  @@index([schoolId, createdAt])
  @@map("notifications")
}

// Fan-out: one row per recipient × channel × notification.
// In-app read state and SMS/email delivery are tracked independently.
// externalId stores the Termii / Arkesel message ID for delivery receipts.
model UserNotification {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  userId         String              @map("user_id")
  channel        NotificationChannel
  isRead         Boolean             @default(false) @map("is_read")
  readAt         DateTime?           @map("read_at")
  deliveredAt    DateTime?           @map("delivered_at")
  failedAt       DateTime?           @map("failed_at")
  externalId     String?             @map("external_id") // SMS gateway message ID
  createdAt      DateTime            @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId, channel])
  @@index([userId, isRead])
  @@map("user_notifications")
}
